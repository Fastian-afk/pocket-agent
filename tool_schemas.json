[
  {
    "tool": "weather",
    "description": "Get weather information for a location",
    "args": {
      "location": {"type": "string", "description": "City or location name"},
      "unit": {"type": "string", "enum": ["C", "F"], "description": "Temperature unit: Celsius (C) or Fahrenheit (F)"}
    },
    "required": ["location", "unit"]
  },
  {
    "tool": "calendar",
    "description": "List or create calendar events",
    "args": {
      "action": {"type": "string", "enum": ["list", "create"], "description": "Action to perform"},
      "date": {"type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$", "description": "Date in YYYY-MM-DD format"},
      "title": {"type": "string", "description": "Event title (required for create, optional for list)"}
    },
    "required": ["action", "date"]
  },
  {
    "tool": "convert",
    "description": "Convert between measurement units",
    "args": {
      "value": {"type": "number", "description": "Numeric value to convert"},
      "from_unit": {"type": "string", "description": "Source unit"},
      "to_unit": {"type": "string", "description": "Target unit"}
    },
    "required": ["value", "from_unit", "to_unit"]
  },
  {
    "tool": "currency",
    "description": "Convert between currencies",
    "args": {
      "amount": {"type": "number", "description": "Amount to convert"},
      "from": {"type": "string", "pattern": "^[A-Z]{3}$", "description": "Source currency ISO 4217 code"},
      "to": {"type": "string", "pattern": "^[A-Z]{3}$", "description": "Target currency ISO 4217 code"}
    },
    "required": ["amount", "from", "to"]
  },
  {
    "tool": "sql",
    "description": "Execute a SQL query",
    "args": {
      "query": {"type": "string", "description": "SQL query string"}
    },
    "required": ["query"]
  }
]
